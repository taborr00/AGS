<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AGS Display Ad</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --green:   #82a14a;
    --blue:    #5673b8;
    --sky:     #94d6dc;
    --yellow:  #dbbc33;
    --coral:   #f16457;
    --ink:     #1a1a1a;
    --soft:    #f7f5f2;
    --border:  #e4e0d8;
    --muted:   #666;
  }

  body {
    font-family: 'Sora', sans-serif;
    background: #edeae4;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 20px;
    gap: 48px;
  }

  /* ====== CONTEXT LABEL ====== */
  .context-label {
    font-size: 11px; letter-spacing: 2px; text-transform: uppercase;
    color: var(--muted); font-family: 'Sora', sans-serif; font-weight: 300;
    margin-bottom: -36px;
  }

  /* ====== BROWSER MOCKUP ====== */
  .browser {
    width: 860px;
    background: white;
    border-radius: 10px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.12);
    overflow: hidden;
  }

  .browser-chrome {
    background: #f0f0f0;
    border-bottom: 1px solid #ddd;
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .b-dots { display: flex; gap: 5px; }
  .b-dot { width: 10px; height: 10px; border-radius: 50%; }
  .b-dot-r { background: #ff5f57; }
  .b-dot-y { background: #febc2e; }
  .b-dot-g { background: #28c840; }
  .b-url {
    flex: 1; background: white; border-radius: 4px;
    padding: 5px 12px; font-size: 12px; color: #666;
    font-family: 'Sora', sans-serif; font-weight: 300;
    border: 1px solid #ddd;
  }

  /* Fake webpage content */
  .webpage {
    padding: 0;
    background: white;
  }

  .webpage-header {
    background: #f7f5f2;
    border-bottom: 1px solid #e4e0d8;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .webpage-logo { font-size: 16px; font-weight: 600; color: #333; font-family: 'Sora', sans-serif; }
  .webpage-nav { display: flex; gap: 20px; }
  .webpage-nav span { font-size: 12px; color: #999; font-family: 'Sora', sans-serif; font-weight: 300; }

  /* AD SLOT LABEL */
  .ad-slot-label {
    text-align: center;
    font-size: 10px;
    color: #bbb;
    padding: 6px;
    background: #fafafa;
    border-bottom: 1px solid #eee;
    font-family: 'Sora', sans-serif;
    letter-spacing: 1px;
  }

  /* ====== THE LEADERBOARD AD ====== */
  .leaderboard {
    width: 728px;
    height: 90px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    display: flex;
    align-items: center;
    background: var(--blue);
    border: 1px solid rgba(255,255,255,0.1);
    transition: filter 0.2s;
  }
  .leaderboard:hover { filter: brightness(1.05); }

  /* Leaf decorations */
  .lb-leaves { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }

  /* Left accent bar */
  .lb-accent {
    width: 5px;
    height: 100%;
    background: linear-gradient(180deg, var(--yellow) 0%, var(--coral) 100%);
    flex-shrink: 0;
    position: relative;
    z-index: 2;
  }

  /* Logo section */
  .lb-logo {
    padding: 0 16px 0 14px;
    display: flex;
    align-items: center;
    border-right: 1px solid rgba(255,255,255,0.15);
    height: 100%;
    flex-shrink: 0;
    position: relative;
    z-index: 2;
  }
  .lb-logo img { height: 52px; width: auto; }

  /* Main content */
  .lb-content {
    flex: 1;
    padding: 0 20px;
    position: relative;
    z-index: 2;
  }

  .lb-eyebrow {
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--sky);
    font-weight: 300;
    margin-bottom: 3px;
  }

  .lb-headline {
    font-size: 19px;
    font-weight: 700;
    color: white;
    line-height: 1.1;
    letter-spacing: -0.3px;
  }
  .lb-headline em {
    font-style: italic;
    font-weight: 300;
    color: var(--yellow);
  }

  .lb-sub {
    font-size: 11px;
    color: rgba(255,255,255,0.6);
    font-weight: 300;
    margin-top: 3px;
    line-height: 1.4;
  }

  /* CTA section */
  .lb-cta {
    padding: 0 20px;
    flex-shrink: 0;
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
  }

  .lb-btn {
    display: inline-block;
    background: var(--green);
    color: white;
    font-family: 'Sora', sans-serif;
    font-size: 11px;
    font-weight: 600;
    padding: 9px 18px;
    border-radius: 2px;
    text-decoration: none;
    letter-spacing: 0.3px;
    white-space: nowrap;
    transition: background 0.2s;
  }
  .lb-btn:hover { background: #6e8c3c; }

  .lb-domain {
    font-size: 9px;
    color: rgba(255,255,255,0.35);
    font-weight: 300;
    letter-spacing: 0.5px;
  }

  /* Right leaf accent */
  .lb-right-leaf {
    position: absolute;
    right: -10px;
    top: -20px;
    width: 80px;
    opacity: 0.12;
    pointer-events: none;
  }

  /* Webpage fake body */
  .webpage-body {
    padding: 24px;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
    opacity: 0.3;
  }
  .fake-block {
    height: 80px;
    background: #f0ece6;
    border-radius: 4px;
  }
  .fake-block.tall { height: 120px; }

  /* ====== ANNOTATION PANEL ====== */
  .annotation-panel {
    width: 860px;
    background: white;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }
  .panel-header {
    background: var(--ink); padding: 13px 22px;
    font-size: 11px; letter-spacing: 2px; text-transform: uppercase;
    color: rgba(255,255,255,0.5); font-weight: 300;
  }
  .panel-body { padding: 22px; display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 18px; }
  .annotation { display: flex; flex-direction: column; gap: 3px; }
  .ann-label { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--green); font-weight: 600; }
  .ann-value { font-size: 13px; color: var(--ink); font-weight: 400; line-height: 1.5; }
  .ann-note { font-size: 12px; color: #999; font-weight: 300; }
</style>
</head>
<body>

<div class="context-label">Leaderboard Display Ad — 728 x 90px</div>

<!-- Browser mockup -->
<div class="browser">
  <div class="browser-chrome">
    <div class="b-dots">
      <div class="b-dot b-dot-r"></div>
      <div class="b-dot b-dot-y"></div>
      <div class="b-dot b-dot-g"></div>
    </div>
    <div class="b-url">familyhistory.ca/alberta-records</div>
  </div>

  <div class="webpage">

    <div class="webpage-header">
      <div class="webpage-logo">FamilyHistory.ca</div>
      <div class="webpage-nav">
        <span>Records</span>
        <span>Search</span>
        <span>About</span>
      </div>
    </div>

    <div class="ad-slot-label">ADVERTISEMENT</div>

    <!-- THE AD -->
    <div style="padding: 8px; background: #f7f5f2; display:flex; justify-content:center; border-bottom: 1px solid #eee;">
      <div class="leaderboard" onclick="window.open('https://www.abgenealogy.ca/','_blank')">

        <div class="lb-leaves">
          <svg style="position:absolute;right:80px;top:-30px;width:100px;opacity:0.15" viewBox="0 0 200 260">
            <path d="M180 10 Q220 80 160 160 Q100 240 20 220 Q80 140 100 80 Q120 20 180 10Z" fill="#f16457"/>
          </svg>
          <svg style="position:absolute;left:200px;bottom:-20px;width:70px;opacity:0.12" viewBox="0 0 200 220">
            <path d="M20 200 Q-20 120 40 60 Q100 0 180 20 Q120 80 90 140 Q60 200 20 200Z" fill="#dbbc33"/>
          </svg>
          <svg style="position:absolute;right:160px;top:10px;width:50px;opacity:0.15" viewBox="0 0 100 140">
            <path d="M80 10 Q110 60 70 110 Q30 160 5 130 Q40 80 50 50 Q60 20 80 10Z" fill="#94d6dc"/>
          </svg>
        </div>

        <div class="lb-accent"></div>

        <div class="lb-logo">
          <img src="data:image/png;base64," alt="AGS">
        </div>

        <div class="lb-content">
          <div class="lb-eyebrow">Alberta Genealogical Society</div>
          <div class="lb-headline">Your story didn&#x2019;t <em>start</em> with you.</div>
          <div class="lb-sub">Expert guidance and exclusive records you won&#x2019;t find online.</div>
        </div>

        <div class="lb-cta">
          <a href="https://www.abgenealogy.ca/" target="_blank" class="lb-btn">Start Your Story</a>
          <div class="lb-domain">abgenealogy.ca</div>
        </div>

      </div>
    </div>

    <div class="webpage-body">
      <div class="fake-block"></div>
      <div class="fake-block tall"></div>
      <div class="fake-block"></div>
    </div>

  </div>
</div>

<!-- Annotation panel -->
<div class="annotation-panel">
  <div class="panel-header">Campaign Annotations</div>
  <div class="panel-body">
    <div class="annotation">
      <span class="ann-label">Ad Format</span>
      <span class="ann-value">Leaderboard 728x90</span>
      <span class="ann-note">Most common display placement, appears at top of page content</span>
    </div>
    <div class="annotation">
      <span class="ann-label">Persona</span>
      <span class="ann-value">Violet, 23yr university student</span>
      <span class="ann-note">Intercepted while browsing genealogy or history-related content</span>
    </div>
    <div class="annotation">
      <span class="ann-label">Headline</span>
      <span class="ann-value">Your story didn't start with you.</span>
      <span class="ann-note">Creates intrigue and speaks to Violet's sense of personal identity</span>
    </div>
    <div class="annotation">
      <span class="ann-label">Supporting Copy</span>
      <span class="ann-value">Expert guidance and exclusive records you won't find online.</span>
      <span class="ann-note">Directly challenges the assumption that big platforms have everything</span>
    </div>
    <div class="annotation">
      <span class="ann-label">CTA</span>
      <span class="ann-value">Start Your Story</span>
      <span class="ann-note">Consistent with campaign, links directly to abgenealogy.ca</span>
    </div>
    <div class="annotation">
      <span class="ann-label">Placement Strategy</span>
      <span class="ann-value">Contextual targeting on genealogy and history sites</span>
      <span class="ann-note">Reaches Violet while she is already in the right headspace</span>
    </div>
  </div>
</div>

</body>
</html>
